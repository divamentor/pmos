import React, { useState } from 'react';

const PROTOCOLS = [
  { id: 1, name: "PROTOKOL_01: TEŞHİS & BİO-MARKER", desc: "HOMA-IR, Serbest Testosteron, DHEA-S ve SHBG takibi.", phase: "Tahlil" },
  { id: 2, name: "PROTOKOL_02: GLUKOZ DİZİLİMİ", desc: "Önce lif, sonra protein ve yağ, en son karbonhidrat dizilimi.", phase: "Beslenme" },
  { id: 3, name: "PROTOKOL_03: HÜCRESEL SİNYAL (İNOSİTOL)", desc: "40:1 oranında Myo/D-Chiro İnositol ile reseptör hassasiyeti.", phase: "Takviye" },
  { id: 4, name: "PROTOKOL_04: ENFLAMASYON BASKILAMA", desc: "NAC (N-Asetilsistein) ile hücresel stres ve antioksidan aktivite.", phase: "Takviye" },
  { id: 5, name: "PROTOKOL_05: ANDROJEN KLİRENSİ", desc: "Çinko ile DHT dönüşüm blokajı, Magnezyum ile kortizol dengesi.", phase: "Takviye" },
  { id: 6, name: "PROTOKOL_06: PROTEİN ÖNCÜLLÜ BAŞLANGIÇ", desc: "İlk... öğünde minimum 30 gram kaliteli protein matrisi.", phase: "Beslenme" },
  { id: 7, name: "PROTOKOL_07: METABOLİK ŞALTER (D3/K2)", desc: "Hedef >50 ng/mL kan düzeyi için sinerjik D3 + K2 takviyesi.", phase: "Takviye" },
  { id: 8, name: "PROTOKOL_08: KORTİZOL MODÜLASYONU", desc: "Sabah aç karnına kahve tüketiminin sonlandırılması (Post-1 Saat).", phase: "Rutin" },
  { id: 9, name: "PROTOKOL_09: LİPİT STABİLİZASYONU", desc: "Karaciğer koruması ve SHBG artışı için yüksek EPA/DHA Omega-3.", phase: "Takviye" },
  { id: 10, name: "PROTOKOL_10: SÜRDÜRÜLEBİLİR REÇETE", desc: "10 dk post-prandiyal yürüyüş, direnç egzersizi ve 7 saat karanlık uyku.", phase: "Rutin" }
];

export default function App() {
  const [activeProtocols, setActiveProtocols] = useState([]);

  const toggleProtocol = (id) => {
    setActiveProtocols(prev => 
      prev.includes(id) ? prev.filter(pId => pId !== id) : [...prev, id]
    );
  };

  const resetAll = () => setActiveProtocols([]);
  const progress = Math.round((activeProtocols.length / PROTOCOLS.length) * 100);

  const getSystemStatus = () => {
    if (progress < 40) return { title: "KRİTİK DEŞARJ (ANDROJEN DOMİNANSI)", color: "text-red-400", desc: "Yüksek LH pulsite frekansı ve matürasyon blokajı aktif." };
    if (progress < 80) return { title: "SİNYAL MODÜLASYONU DEVREDE", color: "text-amber-400", desc: "İnsülin hassasiyeti artıyor, over üzerindeki baskı hafifledi." };
    return { title: "HOMEOSTAZ (SAĞLIKLI DÖNGÜ)", color: "text-emerald-400", desc: "HPO aksı senkronize. Ovülasyon mekanizması optimize edildi." };
  };

  const status = getSystemStatus();

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100 font-mono flex flex-col items-center justify-between p-4 md:p-8">
      
      {/* Üst Header */}
      <header className="w-full max-w-6xl flex justify-between items-center border-b border-slate-800 pb-4 mb-6">
        <div className="flex items-center gap-3">
          <div className="w-3 h-3 bg-emerald-500 rounded-full animate-pulse" />
          <h1 className="text-sm md:text-lg font-bold tracking-widest text-slate-200">DIVA_OS // ENDOKRİN AKIŞ MİMARİSİ</h1>
        </div>
        <div className="text-xs text-slate-500 hidden sm:block">SYS_VER: 1.0.0_PCOS</div>
      </header>

      {/* Ana Panel Kontrol Odası */}
      <main className="w-full max-w-6xl grid grid-cols-1 lg:grid-cols-12 gap-6 items-start flex-grow">
        
        {/* SOL KONSOL: 10 Protokol Kartları */}
        <section className="lg:col-span-7 bg-slate-900/40 border border-slate-800 rounded-2xl p-5 backdrop-blur-md space-y-3">
          <div className="flex justify-between items-center border-b border-slate-800 pb-2 mb-4">
            <h2 className="text-xs font-bold text-slate-400 tracking-wider">AKTİF BİYOLOJİK PROTOKOLLER</h2>
            <button 
              onClick={resetAll} 
              className="text-[10px] text-slate-500 hover:text-red-400 transition-colors border border-slate-800 px-2 py-0.5 rounded"
            >
              TEMİZLE
            </button>
          </div>

          <div className="space-y-2.5 max-h-[65vh] overflow-y-auto pr-1">
            {PROTOCOLS.map((proto) => {
              const isActive = activeProtocols.includes(proto.id);
              return (
                <div 
                  key={proto.id} 
                  onClick={() => toggleProtocol(proto.id)} 
                  className={`w-full text-left p-3.5 rounded-xl border transition-all duration-300 cursor-pointer flex justify-between items-start gap-4 select-none ${
                    isActive ? 'bg-emerald-950/20 border-emerald-500/50 shadow-[inset_0_0_12px_rgba(16,185,129,0.05)]' : 'bg-slate-900/60 border-slate-800/80 hover:border-slate-700'
                  }`}
                >
                  <div className="space-y-1">
                    <div className="flex items-center gap-2">
                      <span className={`text-[9px] px-1.5 py-0.5 rounded border uppercase font-sans tracking-wide ${
                        isActive ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-slate-800 text-slate-400 border-slate-700'
                      }`}>
                        {proto.phase}
                      </span>
                      <h3 className={`text-xs font-bold tracking-wide transition-colors ${isActive ? 'text-emerald-400' : 'text-slate-300'}`}>
                        {proto.name}
                      </h3>
                    </div>
                    <p className="text-xs text-slate-400 font-sans leading-relaxed">{proto.desc}</p>
                  </div>
                  <div className={`w-5 h-5 rounded-md border flex items-center justify-center flex-shrink-0 transition-all ${
                    isActive ? 'border-emerald-500 bg-emerald-500 text-slate-900' : 'border-slate-700 bg-slate-950'
                  }`}>
                    {isActive && (
                      <svg className="w-3.5 h-3.5 stroke-[3]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </section>

        {/* SAĞ KONSOL: Endokrin Akış Görseli & Telemetri Çıktısı */}
        <section className="lg:col-span-5 space-y-6">
          
          {/* HPO Aksı Şeması */}
          <div className="bg-slate-900/40 border border-slate-800 rounded-2xl p-5 backdrop-blur-md relative overflow-hidden">
            <h2 className="text-xs font-bold text-slate-400 tracking-wider border-b border-slate-800 pb-2 mb-6">HPO SİNYAL AKIŞ ŞEMASI</h2>
            
            <div className="flex flex-col items-center justify-between min-h-[240px] relative z-10">
              {/* Hipofiz */}
              <div className={`p-3 rounded-xl border text-center w-48 transition-all duration-500 ${
                progress >= 80 ? 'bg-emerald-950/30 border-emerald-500/40 text-emerald-400' : 'bg-slate-950 border-slate-800'
              }`}>
                <div className="text-[10px] opacity-60">SİNYAL MERKEZİ</div>
                <div className="text-xs font-bold tracking-wide">HİPOFİZ AXIS</div>
                <div className="text-[9px] mt-1 font-sans opacity-80">LH Frekansı: {progress >= 80 ? 'Normal' : 'Kritik/Yüksek'}</div>
              </div>

              {/* Sinyal Akış Hattı */}
              <div className="absolute top-[52px] bottom-[52px] w-0.5 flex flex-col justify-between items-center">
                <div className={`w-0.5 h-full transition-all duration-700 ${
                  progress >= 80 ? 'bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]' : progress >= 40 ? 'bg-amber-500' : 'bg-red-500 animate-pulse'
                }`} />
                <div className={`w-2 h-2 rounded-full absolute transition-all duration-500 ${
                  progress >= 80 ? 'bg-emerald-400 animate-ping' : 'bg-red-400 animate-bounce'
                }`} style={{ top: '40%' }} />
              </div>

              {/* Yumurtalık */}
              <div className={`p-3 rounded-xl border text-center w-48 transition-all duration-500 ${
                progress >= 80 ? 'bg-emerald-950/30 border-emerald-500/40 text-emerald-400' : 'bg-slate-950 border-slate-800'
              }`}>
                <div className="text-[10px] opacity-60">HEDEF ORGAN</div>
                <div className="text-xs font-bold tracking-wide">YUMURTALIK (OVER)</div>
                <div className="text-[9px] mt-1 font-sans opacity-80">Folikül Durumu: {progress >= 80 ? 'Matürasyon Aktif' : 'Gelişimi Yarım'}</div>
              </div>
            </div>
          </div>

          {/* Telemetri Verileri & Skor Ölçer */}
          <div className="bg-slate-900/40 border border-slate-800 rounded-2xl p-5 backdrop-blur-md space-y-5">
            <div>
              <div className="flex justify-between items-end mb-1.5">
                <span className="text-xs font-bold text-slate-400 tracking-wider">HORMONAL STABİLİZASYON SKORU</span>
                <span className={`text-lg font-bold tracking-tight ${progress >= 80 ? 'text-emerald-400' : progress >= 40 ? 'text-amber-400' : 'text-red-400'}`}>
                  %{progress}
                </span>
              </div>
              <div className="w-full h-2 bg-slate-950 rounded-full border border-slate-800 overflow-hidden p-0.5">
                <div 
                  className={`h-full rounded-full transition-all duration-500 ${
                    progress >= 80 ? 'bg-emerald-500' : progress >= 40 ? 'bg-amber-500' : 'bg-red-500'
                  }`}
                  style={{ width: `${progress}%` }}
                />
              </div>
            </div>

            {/* Terminal Tarzı Canlı Sistem Durum Çıktısı */}
            <div className="bg-slate-950 rounded-xl p-3.5 border border-slate-800 space-y-1">
              <div className="text-[9px] text-slate-500">ANLIK TELEMETRİ ÇIKTISI:</div>
              <div className={`text-xs font-bold tracking-wide ${status.color}`}>
                {status.title}
              </div>
              <p className="text-xs text-slate-400 font-sans leading-relaxed pt-1 border-t border-slate-900">
                {status.desc}
              </p>
            </div>
          </div>

        </section>
      </main>

      {/* Yasal Sorumluluk Reddi */}
      <footer className="w-full max-w-6xl text-center border-t border-slate-900 pt-4 mt-6">
        <p className="text-[10px] text-slate-500 font-sans max-w-3xl mx-auto leading-relaxed">
          Bu içerik/araç tamamen bilimsel okuryazarlık ve bilgilendirme amaçlıdır; kişisel tanı, teşhis ve tedavi protokolü içermez. Sağlık durumunuz ve tedavi süreçleriniz için her zaman hekiminize danışın.
        </p>
      </footer>

    </div>
  );
}
